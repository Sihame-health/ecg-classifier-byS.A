@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container-main" style="padding-top: 60px;">
    <div class="upload-card">
        <h1>Privacy Policy</h1>
        <p style="color: #4b5563; line-height: 1.7;">
            This is a personal educational project. When you upload an ECG
            image, it is sent to our prediction API solely to generate a
            classification result (Normal / Abnormal). Uploaded images are
            not stored, logged, or used for any purpose beyond generating
            your immediate result.
        </p>
        <p style="color: #4b5563; line-height: 1.7;">
            No personal data is collected through this site. This project
            is for educational purposes only and does not constitute
            medical advice.
        </p>
        <p style="margin-top: 24px;">
            <a href="/" style="color: #764ba2; font-weight: 600; text-decoration: none;">← Back to home</a>
        </p>
    </div>
</div>